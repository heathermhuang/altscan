# ── BNB Chain RPC (Chainstack Growth — BSC endpoint) ─────────────────────────
BNB_RPC_URL=https://bsc-mainnet.core.chainstack.com/YOUR_KEY

# ── Database (Railway Postgres — bnbscan-db) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/bnbscan

# ── Redis (Railway Redis — bnbscan-redis) ─────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── External enrichment APIs ──────────────────────────────────────────────────
# Moralis — https://moralis.io. Powers address-page history AND token-page holders
# (/erc20/{addr}/owners + /holders). Absent/MORALIS_DISABLED ⇒ holders fall back to local estimate.
MORALIS_API_KEY=
# Per-feature rate caps (calls per hour / per day) — keep history, holders, and assets isolated so
# a spike/abuse in one can't blank the others. Unset ⇒ defaults below, which sum to 1500/hr +
# 10000/day (the previous single-bucket total). holders = getTokenOwners+getTokenHolderCount
# (2 calls/token, ~50 CU each); history/assets ~25 CU/call.
MORALIS_HISTORY_HOURLY_MAX=   # default 700
MORALIS_HISTORY_DAILY_MAX=    # default 5000
MORALIS_HOLDERS_HOURLY_MAX=   # default 400
MORALIS_HOLDERS_DAILY_MAX=    # default 2500
MORALIS_ASSETS_HOURLY_MAX=    # default 400
MORALIS_ASSETS_DAILY_MAX=     # default 2500
# DEPRECATED (ignored by the per-bucket limiter; leave set in prod for rollback safety):
# MORALIS_HOURLY_MAX= / MORALIS_DAILY_MAX=
# CoinGecko demo key (optional) — https://www.coingecko.com/en/api. Absent ⇒ keyless public tier.
COINGECKO_API_KEY=

# ── Network switcher (peer explorer URL) ──────────────────────────────────────
# Production: set to https://ethscan.io
NEXT_PUBLIC_PEER_URL=https://ethscan.io

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
