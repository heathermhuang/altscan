---
import { GITHUB } from '../data/site';
---
<header class="hero wrap">
  <span class="kick">// open-source · multi-chain · block explorer platform</span>
  <h1>The explorer,<br>for every chain.</h1>
  <p class="lede">One open-source engine — one indexer, one schema — powering independent explorers across chains. Two live today, more on the way.</p>
  <div class="cta-row">
    <a class="btn primary" href="#explorers">Open an explorer →</a>
    <a class="btn ghost" href={GITHUB}>View source ↗</a>
  </div>
  <slot />
</header>
